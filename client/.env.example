# React client environment variables
# Copy this file to .env and update the values for your deployment.
# Create React App embeds these values into the build at build time,
# so you must rebuild the client after changing them.

# Base URL of the Laravel API (should end in /api).
# The client derives the storage URL from this value by replacing the
# trailing /api with /storage, so keep /api at the end.
REACT_APP_API_BASE_URL=https://your-domain.com/api

# Optional: explicit base URL for stored files (photos, uploads).
# If omitted, the client will derive it from REACT_APP_API_BASE_URL
# by replacing /api with /storage.
REACT_APP_STORAGE_URL=https://your-domain.com/storage
